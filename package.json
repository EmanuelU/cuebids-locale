{
  "name": "cuebids-locale",
  "type": "module",
  "version": "1.0.0",
  "description": "A package to store and share JSON files for localisation",
  "scripts": {
    "workbench": "vite --config ./workbench/vite.config.js",
    "workbench:build": "vite build --config ./workbench/vite.config.js",
    "workbench:preview": "vite preview --config ./workbench/vite.config.js",
    "test:workbench": "vitest run ./workbench/src/shared/translationUtils.test.js"
  },
  "main": "index.js",
  "keywords": [
    "json",
    "storage",
    "shared",
    "configuration",
    "data"
  ],
  "author": "Emanuel Unge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmanuelU/cuebids-locale.git"
  },
  "bugs": {
    "url": "https://github.com/EmanuelU/cuebids-locale/issues"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
